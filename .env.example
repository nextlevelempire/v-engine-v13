# Omni Browser V4 environment contract
# Isolation guarantee: this repo reads only OMNI_* configuration keys plus standard NODE_ENV.

# REQUIRED: strong 32+ character secret for payload encryption and attach-token signing.
OMNI_PAYLOAD_ENCRYPTION_KEY=replace-with-a-strong-32-plus-character-secret

# OPTIONAL: storage root. Defaults to ~/.omni-browser
OMNI_HOME=.omni-browser

# OPTIONAL: local HTTP port for the standalone server. Defaults to 4011.
OMNI_PORT=4011

# OPTIONAL: payload key version tag written into encrypted state. Defaults to v1.
OMNI_PAYLOAD_ENCRYPTION_KEY_VERSION=v1

# OPTIONAL: allow headless browser fallback if visible Chrome launch fails. Defaults to 0.
OMNI_ALLOW_HEADLESS_FALLBACK=0

# OPTIONAL: attach-token lifetime in milliseconds. Defaults to 300000.
OMNI_ATTACH_TOKEN_TTL_MS=300000

# OPTIONAL: per-agent requests per minute. Defaults to 30.
OMNI_AGENT_RPM=30

# OPTIONAL: short-burst requests per second. Defaults to 10.
OMNI_BURST_RPS=10

# OPTIONAL: per-session requests per minute. Defaults to 60.
OMNI_SESSION_RPM=60

# OPTIONAL: maximum live sessions retained in memory. Defaults to 5.
OMNI_MAX_SESSIONS=5

# OPTIONAL: idle session timeout in milliseconds. Defaults to 900000.
OMNI_IDLE_TIMEOUT_MS=900000

# OPTIONAL: checkpoint interval for warm-state persistence in milliseconds. Defaults to 300000.
OMNI_CHECKPOINT_MS=300000

# OPTIONAL: runtime heartbeat interval in milliseconds. Defaults to 60000.
OMNI_HEARTBEAT_MS=60000

# OPTIONAL: SSE keep-alive heartbeat interval in milliseconds. Defaults to 15000.
OMNI_SSE_HEARTBEAT_MS=15000

# OPTIONAL: artifact quota in megabytes. Defaults to 500.
OMNI_MAX_ARTIFACT_MB=500

# OPTIONAL: artifact retention window in hours. Defaults to 24.
OMNI_MAX_ARTIFACT_AGE_HOURS=24

# OPTIONAL: webhook URL fired on the third refusal strike.
OMNI_SECURITY_WEBHOOK_URL=

# OPTIONAL: scratchpad transcription provider endpoint.
OMNI_FORGE_API_URL=

# OPTIONAL: scratchpad transcription provider key.
OMNI_FORGE_API_KEY=
OMNI_CONTROL_PLANE_URL=
OMNI_INGEST_SECRET=
