# V-Engine production secrets.
# Real values live in `fly secrets set ...` — never commit them.

# Required: HMAC secret for runtime grants. 32+ random bytes, base64url.
OMNI_DASHBOARD_JWT_SECRET=

# Required: daemon instance ID. Stable per deploy.
OMNI_DAEMON_INSTANCE_ID=

# Optional: webhook delivery target.
OMNI_WEBHOOK_URL=
OMNI_WEBHOOK_SECRET=

# Optional: TLS cert paths (in-container, e.g. from Fly's built-in TLS
# or a mounted Secret).
# OMNI_TLS_CERT=/etc/omni/tls/tls.crt
# OMNI_TLS_KEY=/etc/omni/tls/tls.key

# Optional: CORS allowlist (comma-separated origins).
# OMNI_CORS_ALLOWED_ORIGINS=https://app.example.com

# Operational knobs (defaults shown).
OMNI_LISTEN_HOST=0.0.0.0
OMNI_PORT=4011
OMNI_MAX_PARALLEL_SESSIONS=50
OMNI_BODY_SIZE_LIMIT=10485760
OMNI_REQUEST_TIMEOUT_MS=60000
OMNI_AUTH_FAIL_LIMIT=10
OMNI_AUTH_FAIL_WINDOW_MS=60000
OMNI_ACTION_LOG_MAX=10000
OMNI_IDLE_TIMEOUT_MS=900000
OMNI_LOG_LEVEL=info
OMNI_TENANT_SCOPING=off
OMNI_METRICS_DISABLED=0

# Data volume mount.
OMNI_HOME=/data
